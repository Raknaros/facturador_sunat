# ─── Copia este archivo a .env y completa los valores ───────────────────────
# cp .env.example .env

# ── PostgreSQL (base de datos central) ───────────────────────────────────────
DB_HOST=tu-servidor-postgres
DB_PORT=5432
DB_NAME=nombre_de_tu_bd_central
DB_USER=tu_usuario
DB_PASS=cambia_esto_por_una_contrasena_segura

# ── JWT (mínimo 32 caracteres) ────────────────────────────────────────────────
JWT_SECRET=cambia_esto_por_una_clave_jwt_de_al_menos_32_chars

# ── AES-256-GCM (exactamente 32 caracteres) ───────────────────────────────────
ENCRYPTION_KEY=32chars_exactos_aqui_1234567890AB

# ── Modo SUNAT: "beta" (pruebas) o "prod" (producción real) ──────────────────
SUNAT_MODO=beta
